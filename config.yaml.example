# Agentic Memorizer Configuration
#
# This file shows the minimal configuration for most users.
# Many settings have optimal defaults and are not shown here.
# Run 'memorizer config show-schema' to see all available options.

# Memory directory configuration
memory:
  # Root directory for memory files
  root: ~/.memorizer/memory

# Semantic Analysis Configuration
# AI-powered content understanding via Claude, OpenAI, or Gemini
semantic:
  # Enable semantic analysis (requires API key)
  enabled: true

  # Provider: claude, openai, or gemini
  provider: claude

  # API key (or use environment variable: ANTHROPIC_API_KEY, OPENAI_API_KEY, GOOGLE_API_KEY)
  api_key: ""

  # Model (provider-specific)
  # Claude: claude-sonnet-4-5-20250929
  # OpenAI: gpt-4o, gpt-4o-mini
  # Gemini: gemini-2.0-flash, gemini-1.5-pro
  model: claude-sonnet-4-5-20250929

# Background Daemon Configuration
daemon:
  # HTTP server port for API and SSE endpoints (0 to disable)
  http_port: 0

  # Log level: debug, info, warn, error
  log_level: info

# MCP Server Configuration
mcp:
  # Log level for MCP server
  log_level: info

  # Daemon API connectivity (set during 'memorizer initialize')
  # Should match daemon.http_port when enabled
  daemon_host: localhost
  daemon_port: 0

# FalkorDB Knowledge Graph Configuration
graph:
  # FalkorDB host
  host: localhost

  # FalkorDB port
  port: 6379

  # Graph database name
  database: memorizer

  # Password (or use FALKORDB_PASSWORD environment variable)
  password: ""

# Embeddings Configuration (Optional)
# Enable for vector similarity search across your files
embeddings:
  # Enable embeddings (requires API key)
  enabled: false

  # Provider: openai, voyage, or gemini
  provider: openai

  # Model (provider-specific, dimensions auto-derived)
  # OpenAI: text-embedding-3-small (1536d), text-embedding-3-large (3072d)
  # Voyage: voyage-3 (1024d), voyage-3-lite (512d), voyage-code-3 (1024d)
  # Gemini: text-embedding-004 (768d)
  model: text-embedding-3-small

  # API key (or use environment variable: OPENAI_API_KEY, VOYAGE_API_KEY, GOOGLE_API_KEY)
  api_key: ""
