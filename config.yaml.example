# Agentic Memory Configuration

# Root directory for memory files
memory_root: ~/.agentic-memorizer/memory

# Claude API Configuration
claude:
  # API key (set directly or via environment variable)
  api_key: ""

  # Environment variable containing API key (preferred method)
  # Set with: export ANTHROPIC_API_KEY="your-key-here"
  api_key_env: ANTHROPIC_API_KEY

  # Claude model to use
  model: claude-sonnet-4-5-20250929

  # Maximum tokens for each analysis
  max_tokens: 1500

  # Enable vision analysis for images
  enable_vision: true

  # Timeout for API calls (seconds)
  timeout_seconds: 30

# Output Configuration
output:
  # Output format: "xml", "markdown", or "json" (default: xml)
  format: xml

  # Verbose logging
  verbose: false

  # Show files modified in last N days in "Recent Activity" section
  show_recent_days: 7

# Semantic Analysis Configuration
analysis:
  # Enable semantic analysis (requires Claude API key)
  enable: true

  # Maximum file size for analysis (bytes) - 10MB default
  max_file_size: 10485760

  # File extensions to skip analysis
  skip_extensions:
    - .zip
    - .tar
    - .gz
    - .exe
    - .bin
    - .dmg
    - .iso

  # Specific files to skip by name (system files)
  # The binary itself is skipped to avoid self-indexing
  # Config file is in separate directory (~/.agentic-memorizer/) so doesn't need to be skipped
  skip_files:
    - agentic-memorizer

  # Cache directory for semantic analysis results
  cache_dir: ~/.agentic-memorizer/.cache

# Background Daemon Configuration
daemon:
  # Enable daemon mode (background indexing)
  enabled: false

  # Debounce period for file changes (milliseconds)
  # Batches rapid file changes together to avoid excessive rebuilds
  debounce_ms: 500

  # Number of parallel workers for processing files
  workers: 3

  # Rate limit for Claude API calls (per minute)
  # Prevents hitting API rate limits
  rate_limit_per_min: 20

  # Full rebuild interval (minutes)
  # Periodic full scan even if no changes detected
  full_rebuild_interval_minutes: 60

  # Health check HTTP server port (0 to disable)
  # Useful for monitoring daemon status
  health_check_port: 0

  # Log file location
  log_file: ~/.agentic-memorizer/daemon.log

  # Log level: debug, info, warn, error
  log_level: info

# MCP Server Configuration
mcp:
  # Log file for MCP server (when running as MCP server)
  log_file: ~/.agentic-memorizer/mcp.log

  # Log level for MCP server: debug, info, warn, error
  log_level: info

# Integration Configuration
# Tracks which AI agent framework integrations are configured
# Managed automatically by 'integrations setup/remove' commands
integrations:
  enabled: []
