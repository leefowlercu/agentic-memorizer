# Agentic Memory Configuration
#
# This file shows the minimal configuration needed for most users.
# Many settings have optimal defaults and are not shown here.
# For advanced configuration, see docs/configuration.md

# Root directory for memory files
memory_root: ~/.memorizer/memory

# Claude API Configuration
claude:
  # API key (set directly or via ANTHROPIC_API_KEY environment variable)
  api_key: ""

  # Claude model to use
  model: claude-sonnet-4-5-20250929

  # Maximum tokens for each analysis
  max_tokens: 1500

# Semantic Analysis Configuration
analysis:
  # Maximum file size for analysis (bytes) - 10MB default
  max_file_size: 10485760

  # File extensions to skip analysis
  skip_extensions:
    - .zip
    - .tar
    - .gz
    - .exe
    - .bin
    - .dmg
    - .iso

  # Specific files to skip by name (system files)
  skip_files:
    - memorizer

  # Cache directory for semantic analysis results
  cache_dir: ~/.memorizer/.cache

# Background Daemon Configuration
daemon:
  # Debounce period for file changes (milliseconds)
  debounce_ms: 500

  # Number of parallel workers for processing files
  workers: 3

  # Rate limit for Claude API calls (per minute)
  rate_limit_per_min: 20

  # Full rebuild interval (minutes)
  full_rebuild_interval_minutes: 60

  # HTTP server port for health check and SSE endpoints (0 to disable)
  # When enabled, MCP servers can connect for real-time updates
  http_port: 0

  # Log file location
  log_file: ~/.memorizer/daemon.log

  # Log level: debug, info, warn, error
  log_level: info

# MCP Server Configuration
mcp:
  # Log file for MCP server
  log_file: ~/.memorizer/mcp.log

  # Log level for MCP server: debug, info, warn, error
  log_level: info

  # Daemon API connectivity (set automatically during 'integrations setup')
  # The port should match daemon.http_port when enabled
  daemon_host: localhost
  daemon_port: 0

# FalkorDB Knowledge Graph Configuration
graph:
  # FalkorDB host (default: localhost)
  host: localhost

  # FalkorDB port (default: 6379)
  port: 6379

  # Password for FalkorDB authentication (optional, or set FALKORDB_PASSWORD)
  password: ""

  # Minimum similarity threshold for related file recommendations (0.0-1.0)
  similarity_threshold: 0.7

  # Maximum number of similar files to return per query
  max_similar_files: 10

# Embeddings Configuration (Optional)
# Automatically enabled when OPENAI_API_KEY is set
embeddings:
  # API key (set directly or via OPENAI_API_KEY environment variable)
  api_key: ""

# Integration Configuration
# Managed automatically by 'integrations setup/remove' commands
integrations:
  enabled: []
